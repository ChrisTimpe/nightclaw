# OS artifacts
.DS_Store
Thumbs.db
Desktop.ini

# Editor files
*.swp
*.swo
*~
.idea/
.vscode/
*.sublime-project
*.sublime-workspace

# Temporary files
tmp/
*.tmp
*.bak

# Environment files (may contain secrets)
.env
.env.local

# Node/Python artifacts (if scripts are extended)
node_modules/
__pycache__/
*.pyc
.venv/

# NightClaw runtime files — generated by agent, do not commit
memory/*.md
skills/*.md

# Optional: uncomment to exclude populated audit/project files from version control
# audit/AUDIT-LOG.md
# audit/SESSION-REGISTRY.md
# audit/CHANGE-LOG.md
# PROJECTS/*/LONGRUNNER.md
